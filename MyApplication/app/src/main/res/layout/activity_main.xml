<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    tools:context=".MainActivity">

    <ImageButton
        android:id="@+id/btnConfiguracion"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_configuracion"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Configuración"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTranscripcion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@+id/btnConfiguracion" app:layout_constraintBottom_toTopOf="@+id/buttonsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnPararReanudar"
            android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:text="PARAR"
            android:maxLines="1"
            android:layout_marginEnd="2dp" app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="10sp"
            app:autoSizeMaxTextSize="18sp" />

        <Button
            android:id="@+id/btnLimpiar"
            android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:text="LIMPIAR"
            android:maxLines="1"
            android:layout_marginHorizontal="2dp" app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="10sp"
            app:autoSizeMaxTextSize="18sp" />

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:text="GUARDAR"
            android:maxLines="1"
            android:layout_marginStart="2dp" app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="10sp"
            app:autoSizeMaxTextSize="18sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>