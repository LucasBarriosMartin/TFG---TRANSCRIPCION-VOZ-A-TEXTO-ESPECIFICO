<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:layout_marginBottom="16dp"
            android:layout_gravity="start"/>

        <TextView
            android:id="@+id/tvTituloLetra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Elige Tamaño de Letra"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- LETRA NORMAL -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLetraNormal"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="#333333"
                app:strokeWidth="3dp"
                app:strokeColor="#4CAF50">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="A"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- LETRA GRANDE -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLetraGrande"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="50dp"
                app:cardBackgroundColor="#333333"
                app:strokeWidth="3dp"
                app:strokeColor="#4CAF50">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="A"
                    android:textSize="30sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- LETRA GIGANTE -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLetraGigante"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="55dp"
                app:cardBackgroundColor="#333333"
                app:strokeWidth="3dp"
                app:strokeColor="#4CAF50">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="A"
                    android:textSize="40sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="24dp"/>


        <TextView
            android:id="@+id/tvTituloContraste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Elige Contraste y Fondo"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- NEGRO BLANCO -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNegroBlanco"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="#000000"
                app:strokeWidth="3dp"
                app:strokeColor="#4CAF50">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="A"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- BLANCO NEGRO -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBlancoNegro"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="3dp"
                app:strokeColor="#4CAF50">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="A"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- NEGRO AMARILLO -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNegroAmarillo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="#000000"
                app:strokeWidth="3dp"
                app:strokeColor="#4CAF50">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="A"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#FFFF00"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />


    </LinearLayout>

</ScrollView>